generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Play {
  id         String   @id @default(cuid())
  trackId    String
  trackName  String
  artistId   String
  artistName String   @default("")
  playedAt   DateTime
  createdAt  DateTime @default(now())

  @@unique([trackId, playedAt])
  @@index([trackId])
  @@index([playedAt])
  @@index([trackName])
}

model TrackMeta {
  trackId    String   @id
  isrc       String?
  name       String   @default("")
  artistName String   @default("")
  updatedAt  DateTime @updatedAt

  @@index([isrc])
}

model AuthToken {
  id           String   @id @default("spotify")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}

model PlaylistPreference {
  playlistId  String   @id
  position    Int
  description String   @default("")
  updatedAt   DateTime @updatedAt

  @@unique([position])
}

model PlaylistTrackNote {
  id          String   @id @default(cuid())
  playlistId  String
  trackId     String
  trackName   String
  artistNames String
  note        String
  updatedAt   DateTime @updatedAt

  @@unique([playlistId, trackId])
  @@index([playlistId])
}

model AiSortCache {
  id                   String   @id @default(cuid())
  trackId              String
  sourcePlaylistId     String
  inputHash            String
  belongs              Boolean
  suggestedPlaylistId  String?
  reason               String
  updatedAt            DateTime @updatedAt

  @@unique([trackId, sourcePlaylistId, inputHash])
  @@index([sourcePlaylistId, inputHash])
}

model DeletedTrack {
  id            String   @id @default(cuid())
  playlistId    String
  playlistName  String
  trackId       String
  trackName     String
  artistNames   String
  trackUri      String
  albumImageUrl String?
  deletedAt     DateTime @default(now())

  @@index([deletedAt])
  @@index([playlistId])
}

model ShuffleDeck {
  playlistId   String   @id
  usedTrackIds String
  updatedAt    DateTime @updatedAt
}

model PlaylistTrackCache {
  playlistId String   @id
  tracks     String
  updatedAt  DateTime @updatedAt
}
