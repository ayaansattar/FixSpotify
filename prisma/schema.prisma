generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Play {
  id        String   @id @default(cuid())
  trackId   String
  trackName String
  artistId  String
  playedAt  DateTime
  createdAt DateTime @default(now())

  @@unique([trackId, playedAt])
  @@index([trackId])
  @@index([playedAt])
}

model GenreCache {
  artistId String   @id
  genres   String
  updatedAt DateTime @updatedAt
}

model AuthToken {
  id           String   @id @default("spotify")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}

model PlaylistPreference {
  playlistId String   @id
  position   Int
  updatedAt  DateTime @updatedAt

  @@unique([position])
}

model DeletedTrack {
  id          String   @id @default(cuid())
  playlistId  String
  playlistName String
  trackId     String
  trackName   String
  artistNames String
  trackUri    String
  deletedAt   DateTime @default(now())

  @@index([deletedAt])
  @@index([playlistId])
}

model ShuffleDeck {
  playlistId  String   @id
  usedTrackIds String
  updatedAt   DateTime @updatedAt
}

model PlaylistTrackCache {
  playlistId String   @id
  tracks     String
  updatedAt  DateTime @updatedAt
}
