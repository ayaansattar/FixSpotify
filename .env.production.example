# Copy this to .env.production on the server and fill in real values.
# Do NOT commit .env.production.

# The public HTTPS domain that points at this server (used by Caddy for TLS
# and by NextAuth for OAuth callbacks). Example: fixspotify.duckdns.org
APP_DOMAIN=your-domain.example.com

# Spotify app credentials from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must match APP_DOMAIN exactly, including https://
NEXTAUTH_URL=https://your-domain.example.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# SQLite path inside the container (mapped to the app_data volume). Leave as-is.
DATABASE_URL=file:/app/data/prod.db

# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-flash-latest)
# GEMINI_MODEL=gemini-flash-latest
